  { "name": "MoE Lofi", "url": "http://stream.zeno.fm/3u1qndyk8rhvv" },
  { "name": "NIA Radio Lo-Fi", "url": "https://radio.nia.nc/radio/8020/lofi-hq-stream.aac" },
  { "name": "Nightwave Plaza OPUS 96", "url": "http://radio.plaza.one/opus" },
  { "name": "Nightwave Plaza MP3", "url": "http://radio.plaza.one/mp3" },
  { "name": "Radio Caprice Lo-Fi [1]", "url": "http://79.111.14.76:8002/lo-fi" },
