// ═══════════════════════════════════════════════════════
//  ICONS (emoji per station type)
// ═══════════════════════════════════════════════════════
const icons = ['🎵','🎶','🎧','🌙','☁️','🌊','🌿','✨','🎹','🌸'];
function getIcon(idx) { return icons[idx % icons.length]; }

// ═══════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════
let currentIdx = -1;
let isPlaying  = false;

// ═══════════════════════════════════════════════════════
//  ELEMENTS
// ═══════════════════════════════════════════════════════
const audio      = document.getElementById('audioEl');
const grid       = document.getElementById('stationGrid');
const playBtn    = document.getElementById('playBtn');
const playIcon   = document.getElementById('playIcon');
const stName     = document.getElementById('stationName');
const stSub      = document.getElementById('stationSub');
const statusDot  = document.getElementById('statusDot');
const statusLbl  = document.getElementById('statusLabel');
const reel1      = document.getElementById('reel1');
const reel2      = document.getElementById('reel2');
const waveform   = document.getElementById('waveform');
const volSlider  = document.getElementById('volume');
const volVal     = document.getElementById('volVal');
const searchEl   = document.getElementById('search');
const noResults  = document.getElementById('noResults');
const countBadge = document.getElementById('countBadge');
const toast      = document.getElementById('toast');

// ═══════════════════════════════════════════════════════
//  WAVEFORM BARS
// ═══════════════════════════════════════════════════════
(function buildWaveform() {
  const barCount = 32;
  for (let i = 0; i < barCount; i++) {
    const bar = document.createElement('div');
    bar.className = 'waveform-bar';
    const h = 8 + Math.random() * 28;
    bar.style.height = h + 'px';
    const delay = (Math.random() * 0.6).toFixed(2) + 's';
    const dur   = (0.5 + Math.random() * 0.8).toFixed(2) + 's';
    bar.style.setProperty('--d', dur);
    bar.style.animationDelay = delay;
    waveform.appendChild(bar);
  }
})();

// ═══════════════════════════════════════════════════════
//  RENDER STATIONS
// ═══════════════════════════════════════════════════════
let filteredStations = [...stations];

function renderStations(list) {
  grid.innerHTML = '';
  countBadge.textContent = list.length + ' станций';
  noResults.style.display = list.length === 0 ? 'block' : 'none';

  list.forEach((st, i) => {
    const origIdx = stations.indexOf(st);
    const card = document.createElement('div');
    card.className = 'station-card' + (origIdx === currentIdx ? ' active' : '');
    card.dataset.idx = origIdx;

    const domain = (() => {
      try { return new URL(st.url).hostname.replace('www.',''); } catch { return st.url.slice(0,30); }
    })();

    card.innerHTML = `
      <div class="card-icon">${getIcon(origIdx)}</div>
      <div class="card-body">
        <div class="card-name">${escHtml(st.name)}</div>
        <div class="card-url">${escHtml(domain)}</div>
      </div>
      <span class="card-arrow">▶</span>
    `;

    card.addEventListener('click', () => selectStation(origIdx));
    grid.appendChild(card);
  });
}

function escHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

renderStations(filteredStations);

// ═══════════════════════════════════════════════════════
//  SELECT STATION
// ═══════════════════════════════════════════════════════
function selectStation(idx) {
  if (idx === currentIdx && isPlaying) { stopAudio(); return; }
  currentIdx = idx;
  const st = stations[idx];
  stName.textContent = st.name;
  stSub.textContent = 'подключение…';
  playAudio(st.url);
  updateCards();
}

// ═══════════════════════════════════════════════════════
//  PLAY / STOP
// ═══════════════════════════════════════════════════════
function playAudio(url) {
  audio.src = url;
  audio.volume = volSlider.value / 100;
  setStatus('loading');

  const p = audio.play();
  if (p !== undefined) {
    p.catch(() => {
      setStatus('error');
      showToast('⚠ Не удалось подключиться к станции');
    });
  }
}

function stopAudio() {
  audio.pause();
  audio.src = '';
  isPlaying = false;
  setStatus('idle');
  updatePlayBtn();
  waveform.classList.remove('active');
  reel1.classList.remove('spinning');
  reel2.classList.remove('spinning');
}

audio.addEventListener('playing', () => {
  isPlaying = true;
  setStatus('live');
  updatePlayBtn();
  waveform.classList.add('active');
  reel1.classList.add('spinning');
  reel2.classList.add('spinning');
  if (currentIdx >= 0) {
    stSub.textContent = 'в эфире · ' + new URL(stations[currentIdx].url).hostname.replace('www.','');
  }
  showToast('▶ ' + (currentIdx >= 0 ? stations[currentIdx].name : ''));
});

audio.addEventListener('error', () => {
  isPlaying = false;
  setStatus('error');
  updatePlayBtn();
  waveform.classList.remove('active');
  reel1.classList.remove('spinning');
  reel2.classList.remove('spinning');
  stSub.textContent = 'ошибка подключения';
  showToast('⚠ Ошибка потока');
});

audio.addEventListener('pause', () => {
  if (!isPlaying) return;
  isPlaying = false;
  setStatus('idle');
  updatePlayBtn();
  waveform.classList.remove('active');
  reel1.classList.remove('spinning');
  reel2.classList.remove('spinning');
});

// ═══════════════════════════════════════════════════════
//  PLAY BUTTON
// ═══════════════════════════════════════════════════════
playBtn.addEventListener('click', () => {
  if (currentIdx < 0) {
    showToast('Выберите станцию из списка');
    return;
  }
  if (isPlaying) { stopAudio(); }
  else { playAudio(stations[currentIdx].url); }
});

function updatePlayBtn() {
  playIcon.textContent = isPlaying ? '■' : '▶';
}

// ═══════════════════════════════════════════════════════
//  STATUS
// ═══════════════════════════════════════════════════════
function setStatus(state) {
  statusDot.className = 'status-dot';
  if (state === 'live') {
    statusDot.classList.add('live');
    statusLbl.textContent = 'В ЭФИРЕ';
  } else if (state === 'loading') {
    statusLbl.textContent = 'ЗАГРУЗКА…';
  } else if (state === 'error') {
    statusDot.classList.add('error');
    statusLbl.textContent = 'ОШИБКА';
  } else {
    statusLbl.textContent = 'ОСТАНОВЛЕНО';
  }
}

// ═══════════════════════════════════════════════════════
//  CARDS UPDATE
// ═══════════════════════════════════════════════════════
function updateCards() {
  document.querySelectorAll('.station-card').forEach(card => {
    card.classList.toggle('active', parseInt(card.dataset.idx) === currentIdx);
  });
}

// ═══════════════════════════════════════════════════════
//  VOLUME
// ═══════════════════════════════════════════════════════
volSlider.addEventListener('input', () => {
  audio.volume = volSlider.value / 100;
  volVal.textContent = volSlider.value;
});

// ═══════════════════════════════════════════════════════
//  SEARCH
// ═══════════════════════════════════════════════════════
searchEl.addEventListener('input', () => {
  const q = searchEl.value.trim().toLowerCase();
  filteredStations = q ? stations.filter(s => s.name.toLowerCase().includes(q)) : [...stations];
  renderStations(filteredStations);
});

// ═══════════════════════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════════════════════
let toastTimer;
function showToast(msg) {
  toast.textContent = msg;
  toast.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => toast.classList.remove('show'), 3000);
}

// ═══════════════════════════════════════════════════════
//  KEYBOARD
// ═══════════════════════════════════════════════════════
document.addEventListener('keydown', e => {
  if (e.target === searchEl) return;
  if (e.code === 'Space') { e.preventDefault(); playBtn.click(); }
  if (e.code === 'ArrowUp')   { volSlider.value = Math.min(100, +volSlider.value + 5); volSlider.dispatchEvent(new Event('input')); }
  if (e.code === 'ArrowDown') { volSlider.value = Math.max(0,   +volSlider.value - 5); volSlider.dispatchEvent(new Event('input')); }
});
</script>
